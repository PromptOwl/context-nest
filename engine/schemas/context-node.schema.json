{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://promptowl.ai/schemas/context-node.schema.json",
  "title": "Context Node",
  "description": "A single unit of context (document, snippet, glossary, etc.)",
  "type": "object",
  "required": ["id", "title", "type", "owners"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ulid:[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "Unique identifier using ULID format"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Human-readable title for the node"
    },
    "type": {
      "type": "string",
      "enum": [
        "document",
        "snippet",
        "glossary",
        "persona",
        "policy",
        "prompt",
        "tool",
        "reference"
      ],
      "description": "Type of context node"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(user|team|role):[a-zA-Z0-9_-]+$"
      },
      "minItems": 1,
      "description": "List of principals who own this node"
    },
    "scope": {
      "type": "string",
      "enum": ["user", "team", "org", "public", "restricted", "confidential"],
      "default": "user",
      "description": "Visibility scope of the node"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^#[a-zA-Z0-9_-]+$"
      },
      "description": "Tags for categorization and selection"
    },
    "permissions": {
      "type": "object",
      "properties": {
        "read": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Principals allowed to read this node"
        },
        "write": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Principals allowed to modify this node"
        },
        "export": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Principals allowed to export this node (default: empty = deny)"
        }
      },
      "description": "Access control permissions"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Version number (auto-increments on update)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "derived_from": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ulid:[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "description": "Node IDs this was derived from (for lineage tracking)"
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 checksum of content for integrity verification"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "word_count": {
          "type": "integer",
          "minimum": 0
        },
        "token_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        },
        "review_cycle_days": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true,
      "description": "Optional metadata fields"
    }
  },
  "additionalProperties": false
}
