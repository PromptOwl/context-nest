{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://promptowl.ai/schemas/context-pack.schema.json",
  "title": "Context Pack",
  "description": "Saved selector recipe with composition rules and transforms",
  "type": "object",
  "required": ["id", "label", "query"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^pack:[a-zA-Z0-9._-]+$",
      "description": "Unique identifier for the pack"
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable label"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional description of pack purpose"
    },
    "owner": {
      "type": "string",
      "pattern": "^(user|team|role):[a-zA-Z0-9_-]+$",
      "description": "Principal who owns this pack"
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Base selector query"
    },
    "includes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Additional selectors to include (OR logic)"
    },
    "excludes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Selectors to exclude from results"
    },
    "filters": {
      "type": "object",
      "properties": {
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["user", "team", "org", "public", "restricted", "confidential"]
          },
          "description": "Filter by scope values"
        },
        "before": {
          "type": "string",
          "format": "date",
          "description": "Include only nodes created before this date"
        },
        "after": {
          "type": "string",
          "format": "date",
          "description": "Include only nodes created after this date"
        },
        "node_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Filter by node types"
        }
      },
      "additionalProperties": false,
      "description": "Additional filtering criteria"
    },
    "post_transforms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["transform"],
        "properties": {
          "transform": {
            "type": "string",
            "description": "Transform name (e.g., 'summarize:1200', 'redact_pii')"
          },
          "when": {
            "type": "string",
            "description": "Condition expression for when to apply (e.g., 'audience == \"agent\"')"
          },
          "params": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional parameters for the transform"
          }
        },
        "additionalProperties": false
      },
      "description": "Transforms to apply after resolution"
    },
    "audiences": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["internal", "external", "agent", "public"]
      },
      "description": "Intended audiences for this pack"
    },
    "max_tokens": {
      "type": "integer",
      "minimum": 100,
      "description": "Maximum tokens for resolved content (triggers auto-summarization)"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Version number of the pack definition"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "usage_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of times this pack has been resolved"
    },
    "last_used": {
      "type": "string",
      "format": "date-time",
      "description": "Last time this pack was resolved"
    }
  },
  "additionalProperties": false
}
