{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://promptowl.ai/schemas/bundle-manifest.schema.json",
  "title": "Bundle Manifest",
  "description": "Metadata for a resolved context bundle (audit trail and reproducibility)",
  "type": "object",
  "required": ["bundle_id", "selector", "resolved_at", "actor", "nodes"],
  "properties": {
    "bundle_id": {
      "type": "string",
      "pattern": "^ulid:[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "Unique identifier for this bundle"
    },
    "selector": {
      "type": "string",
      "minLength": 1,
      "description": "Selector query used to create this bundle"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of resolution"
    },
    "actor": {
      "type": "string",
      "pattern": "^(user|agent|system):[a-zA-Z0-9_-]+$",
      "description": "Principal who requested this resolution"
    },
    "actor_principals": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "All principals associated with the actor"
    },
    "audience": {
      "type": "string",
      "enum": ["internal", "external", "agent", "public"],
      "description": "Target audience for this bundle"
    },
    "operation": {
      "type": "string",
      "enum": ["resolve", "export"],
      "description": "Operation that created this bundle"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "checksum"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ulid:[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "checksum": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$",
            "description": "Checksum of content after transforms"
          },
          "original_checksum": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$",
            "description": "Checksum of original content before transforms"
          },
          "tokens": {
            "type": "integer",
            "minimum": 0,
            "description": "Estimated token count"
          },
          "transforms_applied": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of transform names applied to this node"
          },
          "transform_chain": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "transform": {
                  "type": "string"
                },
                "checksum_after": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "params": {
                  "type": "object"
                }
              }
            },
            "description": "Detailed chain of transforms with intermediate checksums"
          }
        },
        "additionalProperties": false
      },
      "description": "Nodes included in this bundle"
    },
    "policies_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["policy_id"],
        "properties": {
          "policy_id": {
            "type": "string"
          },
          "conditions_matched": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "actions_taken": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "action": {
                  "type": "string"
                },
                "transform": {
                  "type": "string"
                },
                "target_nodes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "result": {
                  "type": "string",
                  "enum": ["success", "skipped", "failed"]
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        },
        "additionalProperties": false
      },
      "description": "Policies that were applied during resolution"
    },
    "nodes_excluded_by_permission": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of nodes excluded due to permission checks"
    },
    "nodes_excluded_by_policy": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of nodes excluded due to policy deny rules"
    },
    "total_nodes": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of nodes in bundle"
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Total estimated token count"
    },
    "hash_tree": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Root hash of all node checksums (for integrity)"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "description": "Individual node checksums in order"
        },
        "algorithm": {
          "type": "string",
          "default": "sha256",
          "description": "Hashing algorithm used"
        }
      },
      "additionalProperties": false,
      "description": "Merkle tree for bundle integrity verification"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "vault_id": {
          "type": "string",
          "description": "Identifier of the vault used"
        },
        "vault_version": {
          "type": "integer",
          "description": "Version counter of vault at resolution time"
        },
        "cli_version": {
          "type": "string",
          "description": "Version of CLI tool used"
        },
        "engine_version": {
          "type": "string",
          "description": "Version of context engine"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Non-fatal warnings during resolution"
        },
        "performance": {
          "type": "object",
          "properties": {
            "resolution_time_ms": {
              "type": "number"
            },
            "nodes_evaluated": {
              "type": "integer"
            },
            "policies_evaluated": {
              "type": "integer"
            }
          }
        }
      },
      "additionalProperties": true
    },
    "approval": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean"
        },
        "approval_id": {
          "type": "string"
        },
        "approver": {
          "type": "string"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "Approval information if export required approval"
    }
  },
  "additionalProperties": false
}
