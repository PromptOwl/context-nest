{
  "name": "@promptowl/context-engine",
  "version": "0.1.0",
  "description": "Portable, file-based Context OS for AI agents and workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ctx": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:features": "cucumber-js",
    "validate": "node dist/cli/index.js validate",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "demo": "bash scripts/demo.sh",
    "pkg": "pkg dist/cli/index.js --output bin/ctx"
  },
  "keywords": [
    "context",
    "knowledge",
    "ai",
    "llm",
    "prompt-engineering",
    "obsidian",
    "markdown"
  ],
  "author": "PromptOwl",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.5",
    "ora": "^7.0.1",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.1",
    "@types/jest": "^29.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.6",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "pkg": "^5.8.1",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
